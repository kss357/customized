{
    "version": 2,
    "builds": [
      {
        // server.js로부터 Node 서버를 빌드
        "src": "server.js",
        "use": "@vercel/node",
        "config": {
          // views, public 폴더를 함께 번들링
          "includeFiles": [
            "views/**",
            "public/**"
          ]
        }
      }
    ],
    "routes": [
      {
        // 모든 요청을 server.js로 라우팅
        "src": "/(.*)",
        "dest": "server.js"
      }
    ],
    "functions": {
      "server.js": {
        // 필요에 따라 메모리나 실행 시간 제한 설정
        "memory": 1024,
        "maxDuration": 10
      }
    },
    "env": {
      "NODE_ENV": "production"
    }
  }
  