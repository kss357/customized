{
    "version": 2,
    "builds": [
      {
        "src": "server.js",
        "use": "@vercel/node"
      },
      {
        "src": "views/**",
        "use": "@vercel/static"
      }
    ],
    "routes": [
      {
        "src": "/views/(.*)",
        "dest": "/views/$1"
      },
      {
        "src": "/(.*)",
        "dest": "server.js"
      }
    ],
    "functions": {
      "server.js": {
        "memory": 1024,
        "maxDuration": 10
      }
    },
    "env": {
      "NODE_ENV": "production"
    },
    "outputDirectory": ".",
    "public": true,
    "includeFiles": [
      "views/**",
      "public/**"
    ]
  }
  